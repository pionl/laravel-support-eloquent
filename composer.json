{
    "name": "pion/laravel-support-eloquent",
    "description": "Package with small support traits and classes for the Laravel Eloquent models",
    "license": "MIT",
    "authors": [
        {
            "name": "Martin Kluska",
            "email": "martin@kluska.cz"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/database": "^9.0 || ^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6 || ^10.5 || ^11.5 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Pion\\Support\\Eloquent\\": "src/"
        },
        "files": [
            "src/Helpers/model_helper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Pion\\Support\\Eloquent\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
